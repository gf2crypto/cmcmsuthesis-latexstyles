%% ----------------------------------------------------------------
%%  Fira Math  (sans-serif math — unique in TeX Live)
%% ----------------------------------------------------------------
\newcommand{\cmcmsugost@xetex@mathfont@firamath}[1]{%
    \RequirePackage{unicode-math}
    \setmathfont[
        Scale   = #1
    ]{FiraMath-Regular.otf}%
    \setmathfont{texgyredejavu-math.otf}[
        Scale = 1.05,
        range = {
                \top,        % U+22A4
                \vdots,      % U+22EE
                \ddots,      % U+22F1
                \setminus,   % U+2216
            }
    ]
}

