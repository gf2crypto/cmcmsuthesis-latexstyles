%% ----------------------------------------------------------------
%%  PT Serif  (Paratype — best Cyrillic glyphs in TeX Live, TTF)
%% ----------------------------------------------------------------
\newcommand{\cmcmsugostfont@xetex@ptserif}[1]{%
    \RequirePackage{unicode-math}
    \setmainfont[
        BoldFont        = PTF75F.ttf,
        ItalicFont      = PTF56F.ttf,
        BoldItalicFont  = PTF76F.ttf,
        Scale           = #1,
    ]{PTF55F.ttf}%
}

%% ----------------------------------------------------------------
%%  DejaVu Serif  (broad Unicode, full Cyrillic, TTF)
%% ----------------------------------------------------------------
\newcommand{\cmcmsugostfont@xetex@dejavuserif}[1]{%
    \RequirePackage{unicode-math}
    \setmainfont[
        BoldFont        = DejaVuSerif-Bold.ttf,
        ItalicFont      = DejaVuSerif-Italic.ttf,
        BoldItalicFont  = DejaVuSerif-BoldItalic.ttf,
        Scale           = #1
    ]{DejaVuSerif.ttf}%
    \newfontfamily\cyrillicfont[
        BoldFont        = DejaVuSerif-Bold.ttf,
        ItalicFont      = DejaVuSerif-Italic.ttf,
        BoldItalicFont  = DejaVuSerif-BoldItalic.ttf,
        Scale           = #1
    ]{DejaVuSerif.ttf}%
}

