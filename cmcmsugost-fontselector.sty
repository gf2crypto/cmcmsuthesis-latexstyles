%% ----------------------------------------------------------------
%%  PT Serif  (Paratype — best Cyrillic glyphs in TeX Live, TTF)
%% ----------------------------------------------------------------
\newcommand{\cmcmsugost@xetex@ptserif}[1]{%
    \RequirePackage{unicode-math}
    \setmainfont[
        BoldFont        = PTF75F.ttf,
        ItalicFont      = PTF56F.ttf,
        BoldItalicFont  = PTF76F.ttf,
        Scale           = #1,
    ]{PTF55F.ttf}%
}

