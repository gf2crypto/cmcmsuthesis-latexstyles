% cmcmsugost-fontselector.sty
\NeedsTeXFormat{LaTeX2e}[2020-10-01]
\ProvidesPackage{cmcmsugost-fontselector}[2026/03/10 v0.1 package to make easy selecting fonts]
\PassOptionsToPackage{LGR,T2A,T1}{fontenc}
\makeatletter

\RequirePackage{iftex}
\RequirePackage{kvoptions}
\RequirePackage{etoolbox}

\SetupKeyvalOptions{
    family = cmcmsugost,
    prefix = cmcmsugost@
}

%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%
%% font - либо название настроек для группы шрифтов, либо pdflatex
%%      - шрифт,
%%      - либо шрифт с засечками (только для XeLaTeX/LuaLaTeX),
%%      - пример: Times New Roman
%% mathfont - математический шрифт (LaTeX/XeLaTeX/LuaLaTeX)
%% mathfontscale - коэффициент масштабирования для математического
%%                - шрифта, применимо только для XeLaTeX/LuaLaTeX
%% fontscale - коэффициент масштабирования для шрифта serif
%% sans  - шрифт без засечек, sans serif (только XeLaTeX/LuaLaTeX)
%%       - это шрифты обычно используюся в презентациях, пример
%%       - Arial, PType Sans и т.п., также нужны для команд \textsf
%% sansscale - коэффициент масштабирования для шрифта sans
%% mono  - шрифт моноширинный (только для XeLaTeX/LuaLaTeX)
%%       - это шрифты обычно используюся для набора кода
%%       - и листингов, пример Courier, Inconsolata, JetBrains Mono
%% monoscale - коэффициент масштабирования для шрифта mono
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

\DeclareStringOption[default]{font}
\DeclareStringOption[1]{fontscale}

\DeclareStringOption[]{mathfont}
\DeclareStringOption[1]{mathfontscale}

\DeclareStringOption[]{sans}
\DeclareStringOption[1]{sansscale}

\DeclareStringOption[]{mono}
\DeclareStringOption[1]{monoscale}

\ProcessKeyvalOptions*

%% #################################################################
%%  TeX Fonts
%% #################################################################

%% =================================================================
%%     Font Set
%% =================================================================

\newcommand{\cmcmsugost@tex@set@default}{}

\newcommand{\cmcmsugost@tex@set@tempora}{
    \cmcmsugost@tex@tempora%
    \cmcmsugost@tex@mathfont@newtx%
}



%% =================================================================
%%     Text
%% =================================================================

\newcommand{\cmcmsugost@tex@font}{}

\newcommand{\cmcmsugost@tex@tempora}{
    \RequirePackage{tempora}
}


%% =================================================================
%% =================================================================
%%     Math
%% =================================================================

\newcommand{\cmcmsugost@tex@mathfont}{}

\newcommand{\cmcmsugost@tex@mathfont@newtx}{
    \RequirePackage{newtxmath}
    %% Patch to prevent openbox error
    \AddToHook{package/amsthm/before}{%
        \@ifpackageloaded{newtxmath}{
            \let\openbox\undefined%
        }
    }
}
%% #################################################################


%% #################################################################
%%  XeTeX Fonts
%%  #################################################################

%% =================================================================
%%     Font Set
%% =================================================================

\newcommand{\cmcmsugost@xetex@set@default}{
    \RequirePackage[default]{fontsetup}
}

%% =================================================================
%% =================================================================
%%     Main
%% =================================================================
\newcommand{\cmcmsugost@xetex@font}[1]{#1}

%% =================================================================
%% =================================================================
%%     Sans
%% =================================================================
\newcommand{\cmcmsugost@xetex@sans}[1]{#1}

%% =================================================================
%% =================================================================
%%     Mono
%% =================================================================

\newcommand{\cmcmsugost@xetex@mono}[1]{}

%% =================================================================
%% =================================================================
%%     Math
%% =================================================================

\newcommand{\cmcmsugost@xetex@mathfont}[1]{#1}

%% #################################################################

\RequirePackage{iftex}

\ifPDFTeX%
    \@ifundefined{cmcmsugost@tex@set@\cmcmsugost@font}{
        \@ifundefined{cmcmsugost@tex@\cmcmsugost@font}{
            \PackageError{cmcmsugost-fontselector}{
                Unknown font or font set '\cmcmsugost@font' in TeX mode}{}
        }{
            \edef\cmcmsugost@dispatch{%
                cmcmsugost@tex@\cmcmsugost@font}
            \expandafter\csname\cmcmsugost@dispatch\endcsname%
        }
        \@ifundefined{
            cmcmsugost@tex@mathfont@\cmcmsugost@mathfont}{
            \PackageError{cmcmsugost-fontselector}{
                Unknown math font '\cmcmsugost@mathfont' in TeX mode}{}
        }{
            \edef\cmcmsugost@dispatch{%
                cmcmsugost@tex@mathfont@\cmcmsugost@mathfont}
            \expandafter\csname\cmcmsugost@dispatch\endcsname%
        }
    }{
        \edef\cmcmsugost@dispatch{%
            cmcmsugost@tex@set@\cmcmsugost@font}
        \expandafter\csname\cmcmsugost@dispatch\endcsname%
    }
\else%
    % XeTeX/LuaLaTeX
    \@ifundefined{cmcmsugost@xetex@set@\cmcmsugost@font}{
        \@ifundefined{cmcmsugost@xetex@\cmcmsugost@font}{
            \PackageError{cmcmsugost-fontselector}{
                Unknown font or font set '\cmcmsugost@font' in XeTeX/LuaTeX mode}{}
        }{
            \edef\cmcmsugost@dispatch{%
                cmcmsugost@xetex@\cmcmsugost@font}
            \expandafter\csname\cmcmsugost@dispatch%
            \endcsname{\cmcmsugost@fontscale}%
        }
        \@ifundefined{cmcmsugost@xetex@sans@\cmcmsugost@sans}{
            \PackageError{cmcmsugost-fontselector}{
                Unknown sans font '\cmcmsugost@sans' in XeTeX/LuaTeX mode}{}
        }{
            \edef\cmcmsugost@dispatch{%
                cmcmsugost@xetex@sans@\cmcmsugost@sans}
            \expandafter\csname\cmcmsugost@dispatch%
            \endcsname{\cmcmsugost@sansscale}%
        }
        \@ifundefined{cmcmsugost@xetex@mono@\cmcmsugost@mono}{
            \PackageError{cmcmsugost-fontselector}{
                Unknown mono font '\cmcmsugost@mono' in XeTeX/LuaTeX mode}{}
        }{
            \edef\cmcmsugost@dispatch{%
                cmcmsugost@xetex@mono@\cmcmsugost@mono}
            \expandafter\csname\cmcmsugost@dispatch%
            \endcsname{\cmcmsugost@monoscale}%
        }
        \@ifundefined{
            cmcmsugost@xetex@mathfont@\cmcmsugost@mathfont}{
            \PackageError{cmcmsugost-fontselector}{
                Unknown math font '\cmcmsugost@mathfont' in XeTeX/LuaTeX mode}{}
        }{
            \edef\cmcmsugost@dispatch{%
                cmcmsugost@xetex@mathfont@\cmcmsugost@mathfont}
            \expandafter\csname\cmcmsugost@dispatch%
            \endcsname{\cmcmsugost@mathfontscale}%
        }
    }{
        \edef\cmcmsugost@dispatch{%
            cmcmsugost@xetex@set@\cmcmsugost@font}
        \expandafter\csname\cmcmsugost@dispatch\endcsname%
    }

\fi


\makeatother
\endinput
