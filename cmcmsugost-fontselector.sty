% ------------------------------------------------
% Upright Greek helpers (split into pre-font and post-font phases)
% ------------------------------------------------

%% Phase 1 (before font dispatcher):
%%   pdfLaTeX  — load upgreek package
%%   XeLaTeX   — PassOptionsToPackage{math-style=french}{unicode-math}
\newcommand{\cmcmsugostfont@upgreek@preload}{%
    \ifPDFTeX
        \@ifundefined{upalpha}{\RequirePackage{upgreek}}{}%
    \else
        \PassOptionsToPackage{math-style=french}{unicode-math}%
    \fi
}

%% Phase 2 (after font dispatcher, i.e. after fonts are loaded):
%%   pdfLaTeX  — remap Greek letters to upright variants
%%   XeLaTeX   — nothing (math-style=french already took effect)
\newcommand{\cmcmsugostfont@upgreek@remap}{%
    \ifPDFTeX
        \let\alpha\upalpha%
        \let\beta\upbeta%
        \let\gamma\upgamma%
        \let\delta\updelta%
        \let\epsilon\upepsilon%
        \let\varepsilon\upvarepsilon%
        \let\theta\uptheta%
        \let\vartheta\upvartheta%
        \let\lambda\uplambda%
        \let\mu\upmu%
        \let\pi\uppi%
        \let\varpi\upvarpi%
        \let\rho\uprho%
        \let\varrho\upvarrho%
        \let\sigma\upsigma%
        \let\varsigma\upvarsigma%
        \let\phi\upphi%
        \let\varphi\upvarphi%
        \let\omega\upomega%
        \let\Gamma\Upgamma%
        \let\Delta\Updelta%
        \let\Theta\Uptheta%
        \let\Lambda\Uplambda%
        \let\Xi\Upxi%
        \let\Pi\Uppi%
        \let\Sigma\Upsigma%
        \let\Upsilon\Upupsilon%
        \let\Phi\Upphi%
        \let\Psi\Uppsi%
        \let\Omega\Upomega%
    \fi
}

%% Legacy alias (kept for compatibility if called elsewhere)
\newcommand{\cmcmsugostfont@upgreek@apply}{%
    \cmcmsugostfont@upgreek@preload%
    \cmcmsugostfont@upgreek@remap%
}

%% Set mathcal
\newcommand{\cmcmsugostfont@SetMathCalOldStyle}{
    \@ifpackageloaded{unicode-math}{}{
        \RequirePackage{unicode-math}
    }
    \setmathfont[range=\mathcal]{STIXTwoMath-Regular.otf}
}

% ================================================================
% Отложенная загрузка: upgreek, PassOptionsToPackage, диспетчер
% шрифтов и ProvideSymbf — всё выполняется в конце преамбулы,
% чтобы \cmcmsugostfontsetup{...} успел изменить опции.
%
% Порядок:
%   1. upgreek@preload — грузит upgreek (pdfLaTeX) или
%      PassOptionsToPackage (XeLaTeX) ДО шрифтов
%   2. Диспетчер шрифтов — грузит шрифтовые пакеты
%   3. upgreek@remap — переопределяет греческие буквы ПОСЛЕ шрифтов
%   4. ProvideSymbf — обеспечивает \symbf и др. ПОСЛЕ шрифтов
% ================================================================
\AtEndPreamble{%
    %% 1. Pre-font: upgreek / math-style=french (до загрузки шрифтов)
    \ifcmcmsugostfont@upgreek
        \cmcmsugostfont@upgreek@preload
    \fi
    %% 2. Диспетчер загрузки шрифтов
    \ifPDFTeX%
        \@ifundefined{cmcmsugostfont@tex@set@\cmcmsugostfont@font}{
            \@ifundefined{cmcmsugostfont@tex@\cmcmsugostfont@font}{
                \PackageError{cmcmsugost-fontselector}{
                    Unknown font or font set '\cmcmsugostfont@font' in TeX mode}{}
            }{
                \edef\cmcmsugostfont@dispatch{%
                    cmcmsugostfont@tex@\cmcmsugostfont@font}
                \expandafter\csname\cmcmsugostfont@dispatch\endcsname%
            }
            \@ifundefined{%
                cmcmsugostfont@tex@mathfont@\cmcmsugostfont@mathfont}{
                \PackageError{cmcmsugost-fontselector}{
                    Unknown math font '\cmcmsugostfont@mathfont' in TeX mode}{}
            }{
                \edef\cmcmsugostfont@dispatch{%
                    cmcmsugostfont@tex@mathfont@\cmcmsugostfont@mathfont}
                \expandafter\csname\cmcmsugostfont@dispatch\endcsname%
            }
            \@ifundefined{%
                cmcmsugostfont@tex@sans@\cmcmsugostfont@sans}{
                \PackageError{cmcmsugost-fontselector}{
                    Unknown sans font '\cmcmsugostfont@sans' in TeX mode}{}
            }{
                \edef\cmcmsugostfont@dispatch{%
                    cmcmsugostfont@tex@sans@\cmcmsugostfont@sans}
                \expandafter\csname\cmcmsugostfont@dispatch\endcsname%
            }
            \@ifundefined{%
                cmcmsugostfont@tex@mono@\cmcmsugostfont@mono}{
                \PackageError{cmcmsugost-fontselector}{
                    Unknown mono font '\cmcmsugostfont@mono' in TeX mode}{}
            }{
                \edef\cmcmsugostfont@dispatch{%
                    cmcmsugostfont@tex@mono@\cmcmsugostfont@mono}
                \expandafter\csname\cmcmsugostfont@dispatch\endcsname%
            }
        }{
            \edef\cmcmsugostfont@dispatch{%
                cmcmsugostfont@tex@set@\cmcmsugostfont@font}
            \expandafter\csname\cmcmsugostfont@dispatch\endcsname%
        }
    \else%
        % XeTeX/LuaLaTeX
        \@ifundefined{cmcmsugostfont@xetex@set@\cmcmsugostfont@font}{
            \@ifundefined{cmcmsugostfont@xetex@\cmcmsugostfont@font}{
                \PackageError{cmcmsugost-fontselector}{
                    Unknown font or font set '\cmcmsugostfont@font' in XeTeX/LuaTeX mode}{}
            }{
                \edef\cmcmsugostfont@dispatch{%
                    cmcmsugostfont@xetex@\cmcmsugostfont@font}
                \expandafter\csname\cmcmsugostfont@dispatch%
                \endcsname{\cmcmsugostfont@fontscale}%
            }
            \@ifundefined{cmcmsugostfont@xetex@sans@\cmcmsugostfont@sans}{
                \PackageError{cmcmsugost-fontselector}{
                    Unknown sans font '\cmcmsugostfont@sans' in XeTeX/LuaTeX mode}{}
            }{
                \edef\cmcmsugostfont@dispatch{%
                    cmcmsugostfont@xetex@sans@\cmcmsugostfont@sans}
                \expandafter\csname\cmcmsugostfont@dispatch%
                \endcsname{\cmcmsugostfont@sansscale}%
            }
            \@ifundefined{cmcmsugostfont@xetex@mono@\cmcmsugostfont@mono}{
                \PackageError{cmcmsugost-fontselector}{
                    Unknown mono font '\cmcmsugostfont@mono' in XeTeX/LuaTeX mode}{}
            }{
                \edef\cmcmsugostfont@dispatch{%
                    cmcmsugostfont@xetex@mono@\cmcmsugostfont@mono}
                \expandafter\csname\cmcmsugostfont@dispatch%
                \endcsname{\cmcmsugostfont@monoscale}%
            }
            \@ifundefined{%
                cmcmsugostfont@xetex@mathfont@\cmcmsugostfont@mathfont}{
                \PackageError{cmcmsugost-fontselector}{
                    Unknown math font '\cmcmsugostfont@mathfont' in XeTeX/LuaTeX mode}{}
            }{
                \edef\cmcmsugostfont@dispatch{%
                    cmcmsugostfont@xetex@mathfont@\cmcmsugostfont@mathfont}
                \expandafter\csname\cmcmsugostfont@dispatch%
                \endcsname{\cmcmsugostfont@mathfontscale}%
            }
        }{
            \edef\cmcmsugostfont@dispatch{%
                cmcmsugostfont@xetex@set@\cmcmsugostfont@font}
            \expandafter\csname\cmcmsugostfont@dispatch\endcsname%
        }
        \ifcmcmsugostfont@mathcalold%
            \cmcmsugostfont@SetMathCalOldStyle%
        \fi
    \fi

    \ifcmcmsugostfont@microtype%
        \ifPDFTeX%
            \RequirePackage[%
                protrusion=true,
                expansion=true]{microtype}
        \else
            \RequirePackage[%
                protrusion=true,
                expansion=false]{microtype}
        \fi
    \else
        \RequirePackage[%
            protrusion=true,
            expansion=false]{microtype}
    \fi

    %% 3. Post-font: remap Greek letters (pdfLaTeX only, после загрузки шрифтов)
    \ifcmcmsugostfont@upgreek%
        \cmcmsugostfont@upgreek@remap%
    \fi
    %% 4. ProvideSymbf (после загрузки шрифтов)
    \cmcmsugostfont@ProvideSymbf%
}


\makeatother
\endinput
