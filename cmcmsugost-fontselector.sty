        BoldFont        = NewCMMono10-Bold.otf,
        ItalicFont      = NewCMMono10-Italic.otf,
        BoldItalicFont  = NewCMMono10-BoldOblique.otf,
        Scale           = #1
    ]{NewCMMono10-Book.otf}%
    % \newfontfamily\cyrillicfonttt[
    %     BoldFont        = Newcm10-Bold.otf,
    %     ItalicFont      = Newcm10-Italic.otf,
    %     BoldItalicFont  = Newcm10-BoldOblique.otf,
    %     Scale           = #1
    % ]{Newcm10-Book.otf}%
}

%% ----------------------------------------------------------------
%%  JetBrains Mono  (programmer's mono, excellent Cyrillic, ligatures)
%% ----------------------------------------------------------------
\newcommand{\cmcmsugost@xetex@mono@jetbrainsmono}[1]{%
    %% jetbrainsmono — алиас из пакета jetbrainsmono-otf (.fontspec файл)
    %% Без лигатур. Для версии с лигатурами заменить на {jetbrainscode}
    \setmonofont[
        Scale           = #1,
        Contextuals     = AlternateOff
    ]{jetbrainsmono}%
    %% polyglossia требует явного \cyrillicfonttt для шрифтов без Cyrillic OT script tag
    \newfontfamily\cyrillicfonttt[
        Scale           = #1,
        Contextuals     = AlternateOff
    ]{jetbrainsmono}%
}

%% ----------------------------------------------------------------
%%  Julia Mono  (widest Unicode coverage of any mono in TeX Live)
%% ----------------------------------------------------------------
\newcommand{\cmcmsugost@xetex@mono@juliamono}[1]{%
    %% Используем пакет juliamono (tlmgr install juliamono, ~23MB)
    %% Пакет сам вызывает \setmonofont{JuliaMono}[Scale=..., FakeStretch=0.92, ...]
    %% FakeStretch=0.92 — стандартная рекомендация пакета для читаемости
    \PassOptionsToPackage{Scale=#1}{juliamono}%
    \RequirePackage{juliamono}%
    %% polyglossia требует явного \cyrillicfonttt для шрифтов без Cyrillic OT script tag
    \newfontfamily\cyrillicfonttt[
        Scale           = #1,
        FakeStretch     = 0.92,
        Extension       = .ttf,
        UprightFont     = JuliaMono-Regular,
        BoldFont        = JuliaMono-Bold,
        ItalicFont      = JuliaMono-RegularItalic,
        BoldItalicFont  = JuliaMono-BoldItalic
    ]{JuliaMono}%
}

%% ----------------------------------------------------------------
%%  Source Code Pro  (Adobe, full Cyrillic, professional quality)
%% ----------------------------------------------------------------
\newcommand{\cmcmsugost@xetex@mono@sourcecodepro}[1]{%
    %% Используем пакет sourcecodepro (входит в TeX Live fonts-extra)
    %% Аналог: \usepackage[scaled=.95]{sourcecodepro}
    %% Пакет сам вызывает \setmonofont{SourceCodePro} для XeLaTeX
    \PassOptionsToPackage{scale=#1}{sourcecodepro}%
    \RequirePackage{sourcecodepro}%
    % %% polyglossia требует явного \cyrillicfonttt для шрифтов без Cyrillic OT script tag
    % \newfontfamily\cyrillicfonttt[
    %     Scale           = #1
    % ]{SourceCodePro-Regular.otf}%
}
