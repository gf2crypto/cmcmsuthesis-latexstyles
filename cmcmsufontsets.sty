%% ----------------------------------------------------------------
%%  Latin Modern Math  (CM-style Unicode math, de-facto standard)
%% ----------------------------------------------------------------
\newcommand{\cmcmsugostfont@xetex@mathfont@lmmath}[1]{%
    \RequirePackage{unicode-math}
    \setmathfont[
        Scale   = #1
    ]{latinmodern-math.otf}%
}

%% ----------------------------------------------------------------
%%  Libertinus Math  (modern, actively developed, pair to Libertine)
%% ----------------------------------------------------------------
\newcommand{\cmcmsugostfont@xetex@mathfont@libertinusmath}[1]{%
    \RequirePackage{unicode-math}
    \setmathfont[
        Scale   = #1
    ]{LibertinusMath-Regular.otf}%
}

%% ----------------------------------------------------------------
%%  STIX Two Math  (maximum symbol coverage of all Unicode Math fonts)
%% ----------------------------------------------------------------
\newcommand{\cmcmsugostfont@xetex@mathfont@stixmath}[1]{%
    \RequirePackage{unicode-math}
    \setmathfont[
        Scale   = #1
    ]{STIXTwoMath-Regular.otf}%
}

%% ----------------------------------------------------------------
%%  NewCM Math Book  (CM-style, wide Unicode math)
%% ----------------------------------------------------------------
\newcommand{\cmcmsugostfont@xetex@mathfont@newcm}[1]{%
    \typeout{Loading NewCMMath font}
    \RequirePackage{unicode-math}
    \setmathfont[
        Scale   = #1
    ]{NewCMMath-Book.otf}%
}

%% ----------------------------------------------------------------
%%  Garamond Math  (Garamond-style, elegant)
%% ----------------------------------------------------------------
\newcommand{\cmcmsugostfont@xetex@mathfont@garamondmath}[1]{%
    \RequirePackage{unicode-math}
    \setmathfont[
        Scale   = #1
    ]{Garamond-Math.otf}%
}

%% ----------------------------------------------------------------
%%  Fira Math  (sans-serif math — unique in TeX Live)
%% ----------------------------------------------------------------
\newcommand{\cmcmsugostfont@xetex@mathfont@firamath}[1]{%
    \RequirePackage{unicode-math}
    \setmathfont[
        Scale   = #1
    ]{FiraMath-Regular.otf}%
    \setmathfont{texgyredejavu-math.otf}[
        Scale = 1.05,
        range = {
                \top,        % U+22A4
                \vdots,      % U+22EE
                \ddots,      % U+22F1
                \setminus,   % U+2216
                \star,       % U+22C6
            }
    ]
}

%% ----------------------------------------------------------------
%%  kpfonts-otf Math  (rich symbol set, OTF version)
%% ----------------------------------------------------------------
\newcommand{\cmcmsugostfont@xetex@mathfont@kpmath}[1]{%
    \RequirePackage{unicode-math}
    \setmathfont[
        Scale   = #1
    ]{KpMath-Regular.otf}%
}

