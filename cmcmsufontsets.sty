%% ################################################################
%%
%%  Brill — академический шрифт издательства Brill (Лейден).
%%  Гуманистическая антиква, ~7000 глифов, полная кириллица,
%%  политонический греческий, МФА, старостильные цифры, small caps.
%%  Скачать бесплатно: brill.com/about/brill-fonts
%%  Установка: cp Brill-*.ttf ~/Library/texmf/fonts/truetype/brill/
%%             mktexlsr
%%
%% ################################################################

\newcommand{\cmcmsugostfont@xetex@brillkp}[1]{%
    \typeout{Loading Brill KP: Brill + KPMath + Alegreya Sans + Iosevka}%
    \cmcmsugostfont@xetex@brill{1}%
    \cmcmsugostfont@xetex@sans@alegreyasans{0.98}%
    \cmcmsugostfont@xetex@mono@iosevkabrill{MatchLowercase}%
    % \cmcmsugostfont@xetex@mono@sourcecodepro{MatchLowercase}
    \cmcmsugostfont@xetex@mathfont@kpmath{MatchLowercase}%
    \cmcmsugostfont@SetMathCalOldStyle%
}

