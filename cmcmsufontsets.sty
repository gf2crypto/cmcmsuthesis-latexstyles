\newcommand{\cmcmsugostfont@xetex@ptsans}[1]{%
    \typeout{Loading PT Sans font set}%
    \cmcmsugostfont@xetex@sans@ptsans{1}%
    \RequirePackage{unicode-math}
    \setmainfont[
        BoldFont        = PTS75F.ttf,
        ItalicFont      = PTS56F.ttf,
        BoldItalicFont  = PTS76F.ttf
    ]{PTS55F.ttf}%
    \cmcmsugostfont@xetex@sans@ptsansnarrow{1}%
    \cmcmsugostfont@xetex@mono@ptmono{MatchLowercase}%
    \cmcmsugostfont@xetex@mathfont@stixmath{1}%
}

