\makeatletter

\RequirePackage{iftex}
\RequirePackage{kvoptions}

\SetupKeyvalOptions{
    family = cmcmsugost,
    prefix = cmcmsugost@
}

% Цвет
% \RequirePackage[dvipsnames, table]{xcolor}
% Интервал
\RequirePackage{setspace}
% Геометрия документа
\RequirePackage{geometry}
% Поддержка работы с переносами
\RequirePackage{hyphenat}


\newcommand{\cmcmsugost@FixOverfullBoxes}{
    %  Выравнивание и переносы
    % http://tex.stackexchange.com/questions/241343/what-is-the-meaning-of-fussy-sloppy-emergencystretch-tolerance-hbadness
    % http://www.latex-community.org/forum/viewtopic.php?p=70342%p70342
    \tolerance 1414%
    \hbadness 1414%
    % В случае проблем регулировать в первую очередь
    \emergencystretch 1.5em
    \hfuzz 0.3pt
    \vfuzz \hfuzz%
    \raggedbottom%
    % Избавляемся от переполнений
    \sloppy
    % Запрещаем разрыв страницы после первой строки абзаца
    \clubpenalty=10000
    % Запрещаем разрыв страницы после последней строки абзаца
    \widowpenalty=10000
    % Ограничение на разрыв страницы, если строка заканчивается переносом
    \brokenpenalty=4991
}

% Настройка колонтитулов
\RequirePackage{fancyhdr}
\newcommand{\cmcmsugost@SetHeaderAndFooterSty}{
    \pagestyle{fancy}
    \fancyhf{} % clear all header fields
    \fancyhead[C]{\rmfamily\thepage}
    \renewcommand{\headrulewidth}{0pt}
    \fancyheadoffset{3cm}  % left margin (see geometry)
    \setlength{\headheight}{\baselineskip}
}


% Detect chapter presence
\newif\ifcmcmsugost@haschapter%

    \@ifundefined{chapter}{
        \cmcmsugost@haschapterfalse
    }{
        \cmcmsugost@haschaptertrue
    }


    % Оформление заголовков глав, разделов, подразделов
    % Работа должна быть выполнена ... размером шрифта 12-14 пунктов (ГОСТ Р 7.0.11-2011, 5.3.8). То есть не должно быть надписей шрифтом более 14. Так и поставим.
    % Эти установки будут давать одинаковый результат независимо от выбора базовым шрифтом 12 пт или 14 пт
    % Titlesec headings (note: chapter spacing requires formatting as per titlesec manual)
    \RequirePackage{titlesec}
    \newcommand{\cmcmsugost@sectionfont}{\fontsize{14pt}{16pt}\selectfont\bfseries}



    \newcommand{\cmcmsugost@SetTitleSectionSty}{
        \titleformat{\section}{\cmcmsugost@sectionfont}{\thesection\space}{0pt}{}[]
        \titlespacing{\section}{0pt}{\cmcmsugost@titleskip}{\cmcmsugost@titleskip}
        \titleformat{\subsection}{\cmcmsugost@sectionfont}{\thesubsection\space}{0pt}{}[]
        \titlespacing{\subsection}{0pt}{\cmcmsugost@titleskip}{\cmcmsugost@titleskip}
        \titleformat{\subsubsection}{\cmcmsugost@sectionfont}{\thesubsubsection\space}{0pt}{}[]
        \titlespacing{\subsubsection}{0pt}{\cmcmsugost@titleskip}{\cmcmsugost@titleskip}
    }

    \newcommand{\cmcmsugost@SetTitleSty}{
        \AtEndPreamble{
            % Коэффициент кратности к размеру шрифта
            \newlength{\cmcmsugost@titleskip}
            \setlength{\cmcmsugost@titleskip}{3\f@size\p@} % 3 * current base font size
            \ifcmcmsugost@haschapter%
                \titleformat{\chapter}{
                    \cmcmsu@gost@sectionfont
                }{
                    \chaptertitlename\space\thechapter.\space
                }{0pt}{}[]
                \titlespacing{\chapter}{0pt}{-\headheight}{
                    \cmcmsu@gost@titleskip}
            \else
                \newcommand{\sectionbreak}{\clearpage}
            \fi
            \cmcmsugost@SetTitleSectionSty
        }
    }


    \RequirePackage[titles]{tocloft}
    \newcommand{\cmcmsugost@SetToCSty}{
        % ToC title name (Russian)
        \@ifundefined{captionsrussian}
        {}
        {\addto\captionsrussian{
                \renewcommand{\contentsname}{Оглавление}}}
        % Отбивка точками до номера страницы начала главы/раздела
        \ifcmcmsugost@haschapter
            \renewcommand{\cftchapleader}{
                \cftdotfill{\cftdotsep}}
            \renewcommand{\cftchapterleader}{
                \cftdotfill{\cftchapterdotsep}}
            % Нежирные номера страниц у глав в оглавлении
            \renewcommand{\cftchappagefont}{\normalfont}
            % нежирные точки до номеров страниц у глав в оглавлении
            % \renewcommand{\cftchapterleader}{\cftdotfill{\cftchapterdotsep}}
            % добавляет точку с пробелом после номера подраздела в оглавлении
            \renewcommand\cftchapaftersnum{.\space}
        \fi

        \renewcommand{\cftsecleader}{\cftdotfill{\cftdotsep}}
        % Переносить слова в заголовке не допускается (ГОСТ Р 7.0.11-2011, 5.3.5). Заголовки в оглавлении должны точно повторять заголовки в тексте (ГОСТ Р 7.0.11-2011, 5.2.3). Прямого указания на запрет переносов в оглавлении нет, но по той же логике невнесения искажений в смысл, лучше в оглавлении не переносить:
        \renewcommand\@tocrmarg{2.55em plus1fill} % versus 2.55em
        % Нежирные номера страниц у глав в оглавлении
        \renewcommand{\cftsecpagefont}{\normalfont}
        % нежирные точки до номеров страниц у глав в оглавлении
        % добавляет точку с пробелом после номера подраздела в оглавлении
        \renewcommand\cftsecaftersnum{.\space}
        \renewcommand\cftsubsecaftersnum{.\space}
        \renewcommand\cftsubsubsecaftersnum{.\space}
    }

    % По ГОСТ 2.105, п. 4.3.8 Приложения обозначают заглавными буквами русского алфавита,
    % начиная с А, за исключением букв Ё, З, Й, О, Ч, Ь, Ы, Ъ.
    % Здесь также переделаны все нумерации русскими буквами.
    \newcommand{\cmcmsugost@patchrualpha}{
        \if@uni@ode
            \def\russian@Alph%1{\ifcase%1\or
            А\or Б\or В\or Г\or Д\or Е\or Ж\or
            И\or К\or Л\or М\or Н\or
            П\or Р\or С\or Т\or У\or Ф\or Х\or
            Ц\or Ш\or Щ\or Э\or Ю\or Я\else\@ctrerr\fi}
\else
    \def\russian@Alph%1{\ifcase%1\or
    \CYRA\or\CYRB\or\CYRV\or\CYRG\or\CYRD\or\CYRE\or\CYRZH\or
    \CYRI\or\CYRK\or\CYRL\or\CYRM\or\CYRN\or
    \CYRP\or\CYRR\or\CYRS\or\CYRT\or\CYRU\or\CYRF\or\CYRH\or
    \CYRC\or\CYRSH\or\CYRSHCH\or\CYREREV\or\CYRYU\or
    \CYRYA\else\@ctrerr\fi}
\fi
\if@uni@ode
    \def\russian@alph%1{\ifcase%1\or
    а\or б\or в\or г\or д\or е\or ж\or
    и\or к\or л\or м\or н\or
    п\or р\or с\or т\or у\or ф\or х\or
    ц\or ш\or щ\or э\or ю\or я\else\@ctrerr\fi}
\else
\def\russian@alph%1{\ifcase%1\or
\cyra\or\cyrb\or\cyrv\or\cyrg\or\cyrd\or\cyre\or\cyrzh\or
\cyri\or\cyrk\or\cyrl\or\cyrm\or\cyrn\or
\cyrp\or\cyrr\or\cyrs\or\cyrt\or\cyru\or\cyrf\or\cyrh\or
\cyrc\or\cyrsh\or\cyrshch\or\cyrerev\or\cyryu\or
\cyrya\else\@ctrerr\fi}
\fi
}

% Слово 'Приложение' в оглавлении
\newcommand{\cmcmsugost@SetAppendixSty}{%
    \ifcmcmsugost@haschapter%
        \newcommand\appendix@chapter[1]{%
        \refstepcounter{chapter}%
    \orig@chapter*{Приложение \russian@Alph\c@chapter\space %1}%
        \addcontentsline{toc}{chapter}{%
            Приложение \russian@Alph\c@chapter. %1}%
        }
        \let\orig@chapter\chapter%
        \g@addto@macro\appendix{\let\chapter\appendix@chapter
            \renewcommand{\thechapter}{
                \russian@Alph{\value{chapter}}}%
        }
    \else
        \newcommand\appendix@section[1]{%
        \refstepcounter{section}%
    \orig@section*{Приложение \russian@Alph\c@section\space %1}%
        \addcontentsline{toc}{section}{
            Приложение \russian@Alph\c@section. %1}%
        }
        \let\orig@section\section%
        \g@addto@macro\appendix{\let\section\appendix@section
            \renewcommand{\thesection}{\russian@Alph{\value{section}}}%
        }
    \fi
}

%+% Стр. над номерами страниц в оглавлении
% http://tex.stackexchange.com/a/306950
\RequirePackage{afterpage}
\newcommand{\cmcmsugost@ToCAddPageWord}{
    \newif\ifendTOC%
    %+LATEX_HEADER_EXTRA:
    \newcommand*{\tocheader}{
        \ifendTOC\else\hbox to \linewidth%
            {\hfill{Стр.}}\par%
            \ifnumless{\value{page}}{3}{}{%
                \vspace{0.5\baselineskip}
            }
            \afterpage{\tocheader}
        \fi%
    }
    \let\tableofcontentsORIG\tableofcontents
    \renewcommand\tableofcontents{
        \tableofcontentsORIG%
        \addtocontents{toc}{\protect\tocheader}
        \endTOCtrue%
        \newpage%
    }
}

% Модификация списков
\RequirePackage{enumitem}

\newcommand{\cmcmsugost@SetListSty}{
    % Используем короткое тире (endash) для ненумерованных списков (ГОСТ 2.105-95, пункт 4.1.7, требует дефиса, но так лучше смотрится)
    \renewcommand{\labelitemi}{\normalfont\bfseries{--}}
    \renewcommand{\labelitemii}{\normalfont\bfseries{--}}
    \renewcommand{\labelitemiii}{\normalfont\bfseries{--}}
    \renewcommand{\labelitemiv}{\normalfont\bfseries{--}}
    %+LATEX_HEADER_EXTRA:
    % Перечисление строчными буквами латинского алфавита (ГОСТ 2.105-95, 4.1.7)
    \makeatletter
    \AddEnumerateCounter{\asbuk}{\russian@alph}{щ}
    \makeatother
    \renewcommand{\theenumii}{\asbuk{enumii}}
    \renewcommand{\labelenumii}{\theenumii)}
    \renewcommand{\theenumiii}{\arabic{enumiii}}
    \renewcommand{\labelenumiii}{\theenumiii)}
    \setlist{nosep,                % Единый стиль для всех списков (пакет enumitem), без дополнительных интервалов.
        labelindent=\parindent,leftmargin=*%            % Каждый пункт, подпункт и перечисление записывают с абзацного отступа (ГОСТ 2.105-95, 4.1.8)
    }
}


\RequirePackage{captions}

\newcommand{\cmcmsugost@SetFigureSty}{
    \DeclareCaptionLabelSeparator{figsep}{~---\ } % нумерация рисунков
    %+LATEX_HEADER_EXTRA:
    \captionsetup[figure]{
        format=plain,                     % формат подписи (plain|hang)
        font=normal,                      % нормальные размер, цвет, стиль шрифта
        skip=.0pt,                        % отбивка под подписью
        parskip=.0pt,                     % отбивка между параграфами подписи
        position=below,                   % положение подписи
        singlelinecheck=true,             % выравнивание по центру, если умещается в одну строку
        justification=centerlast,         % центровка
        labelsep=figsep,                  % разделитель
    }

    % Подписи подрисунков
    \DeclareCaptionSubType{figure}
    \renewcommand\thesubfigure{\asbuk{subfigure}} % нумерация подрисунков
    \DeclareCaptionFont{norm}{\fontsize{14pt}{16pt}\selectfont}
    %+LATEX_HEADER_EXTRA:
    \captionsetup[subfloat]{
        labelfont=norm,                 % нормальный размер подписей подрисунков
        textfont=norm,                  % нормальный размер подписей подрисунков
        labelsep=space,                 % разделитель
        labelformat=brace,              % одна скобка справа от номера
        justification=centering,        % центровка
        singlelinecheck=true,           % выравнивание по центру, если умещается в одну строку
        skip=0.pt,            % отбивка над подписью
        parskip=.0pt,                   % отбивка между параграфами подписи
        position=below,                 % положение подписи
    }
}

% Таблицы
\newcommand{\cmcmsugost@SetTableSty}{
\DeclareCaptionLabelSeparator{tabsep}{~---\ } % нумерация таблиц
\DeclareCaptionFormat{split}{\splitformatlabel%1\par\splitformattext%3}
    \captionsetup[table]{
        format=plain,  % формат подписи (plain|hang)
        font=normal,                      % нормальные размер, цвет, стиль шрифта
        skip=.0pt,                        % отбивка под подписью
        parskip=.0pt,                     % отбивка между параграфами подписи
        position=above,                   % положение подписи
        justification=justified,           % центровка
        indent=0cm,                % смещение строк после первой
        labelsep=tabsep,                  % разделитель
        singlelinecheck=false, % не выравнивать по центру, если умещается в одну строку
    }
}

% Кириллица в нумерации subequations
% Для правильной работы требуется выполнение сразу после загрузки пакетов
\newcommand{\cmcmsugost@SetEquationSty}{

    \AtEndPreamble{  \patchcmd{\subequations}{
            \def\theequation{\theparentequation\alph{equation}}}
        {\def\theequation{\theparentequation\asbuk{equation}}}
        {\typeout{subequations patched}}{
            \typeout{subequations not patched}}
    }
}

\newcommand{\cmcmsugost@ApplySty}{
    \cmcmsugost@FixOverfullBoxes
    \cmcmsugost@SetTitleSty
    \cmcmsugost@SetHeaderAndFooterSty
    \cmcmsugost@SetToCSty
    \cmcmsugost@SetAppendixSty
    \cmcmsugost@SetFigureSty
    \cmcmsugost@SetListSty
    \cmcmsugost@SetEquationSty
    \cmcmsugost@SetTableSty
    \RequirePackage{indentfirst}
    \RequirePackage{hyperref}
    \hypersetup{linktoc=page}
    \geometry{a4paper,
        top=2cm,
        bottom=2cm,
        left=2.5cm,
        right=1cm,
        nofoot,
        nomarginpar}
    \onehalfspacing%
}

\cmcmsugost@ApplySty

