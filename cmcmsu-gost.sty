\RequirePackage{hyphenat}


\newcommand{\cmcmsugost@FixOverfullBoxes}{
    %  Выравнивание и переносы
    % http://tex.stackexchange.com/questions/241343/what-is-the-meaning-of-fussy-sloppy-emergencystretch-tolerance-hbadness
    % http://www.latex-community.org/forum/viewtopic.php?p=70342%p70342
    \tolerance 1414%
    \hbadness 1414%
    % В случае проблем регулировать в первую очередь
    \emergencystretch 1.5em
    \hfuzz 0.3pt
    \vfuzz \hfuzz%
    \raggedbottom%
    % Избавляемся от переполнений
    \sloppy
    % Запрещаем разрыв страницы после первой строки абзаца
    \clubpenalty=10000
    % Запрещаем разрыв страницы после последней строки абзаца
    \widowpenalty=10000
    % Ограничение на разрыв страницы, если строка заканчивается переносом
    \brokenpenalty=4991
}

% Настройка колонтитулов
\RequirePackage{fancyhdr}
\newcommand{\cmcmsugost@SetHeaderAndFooter}{
    \pagestyle{fancy}
    \fancyhf{} % clear all header fields
    \fancyhead[C]{\rmfamily\thepage}
    \renewcommand{\headrulewidth}{0pt}
    \fancyheadoffset{3cm}  % left margin (see geometry)
    \setlength{\headheight}{\baselineskip}
}

% Оформление заголовков глав, разделов, подразделов
% Работа должна быть выполнена ... размером шрифта 12-14 пунктов (ГОСТ Р 7.0.11-2011, 5.3.8). То есть не должно быть надписей шрифтом более 14. Так и поставим.
% Эти установки будут давать одинаковый результат независимо от выбора базовым шрифтом 12 пт или 14 пт
% Коэффициент кратности к размеру шрифта
\newcounter{intvl}
\setcounter{intvl}{3}
% Установки для размера шрифта 14 pt
\newlength{\curtextsize}
\newlength{\bigtextsize}
\setlength{\bigtextsize}{13.9pt}
\setlength{\curtextsize}{\f@size pt}


\newcommand{\basegostsectionfont}{\fontsize{14pt}{16pt}\selectfont\bfseries}
\titleformat{\section}{\basegostsectionfont}{\thesection\space}{0pt}{}[]
\newcommand{\sectionbreak}{\clearpage}
\titlespacing{\section}{0pt}{\theintvl\curtextsize}{\theintvl\curtextsize}
\titleformat{\subsection}{\basegostsectionfont}{\thesubsection\space}{0pt}{}[]
\titlespacing{\subsection}{0pt}{\theintvl\curtextsize}{\theintvl\curtextsize}
\titleformat{\subsubsection}{\basegostsectionfont}{\thesubsubsection\space}{0pt}{}[]
\titlespacing{\subsubsection}{0pt}{\theintvl\curtextsize}{\theintvl\curtextsize}
% Оформление заголовков глав, разделов, подразделов
% Работа должна быть выполнена ... размером шрифта 12-14 пунктов (ГОСТ Р 7.0.11-2011, 5.3.8). То есть не должно быть надписей шрифтом более 14. Так и поставим.
% Эти установки будут давать одинаковый результат независимо от выбора базовым шрифтом 12 пт или 14 пт
% Коэффициент кратности к размеру шрифта
\newcounter{intvl}
\setcounter{intvl}{3}
% Установки для размера шрифта 14 pt
\newlength{\curtextsize}
\newlength{\bigtextsize}
\setlength{\bigtextsize}{13.9pt}
\newlength{\titleskip}
\makeatletter
\AtBeginDocument{%
    \setlength{\curtextsize}{\f@size pt}%
    \setlength{\titleskip}{\dimexpr\c@intvl\curtextsize\relax}%
}
