\newcommand{\cmcmsugost@FixOverfullBoxes}{%
    \tolerance=1414\relax
    \hbadness=1414\relax
    \emergencystretch=1.5em\relax
    \hfuzz=0.3pt\relax
    \vfuzz=\hfuzz
    \raggedbottom
    \sloppy
    \clubpenalty=10000
    \widowpenalty=10000
    \brokenpenalty=4991
}

% Колонтитулы
\RequirePackage{fancyhdr}
\newcommand{\cmcmsugost@SetHeaderAndFooterSty}{%
    \pagestyle{fancy}%
    \fancyhf{}%
    \fancyhead[C]{\rmfamily\thepage}%
    \renewcommand{\headrulewidth}{0pt}%
    \fancyheadoffset{3cm}%
    \setlength{\headheight}{\baselineskip}%
}

% Есть ли chapter?
\newif\ifcmcmsugost@haschapter
\@ifundefined{chapter}{%
    \cmcmsugost@haschapterfalse
}{%
    \cmcmsugost@haschaptertrue
}

% Заголовки
\RequirePackage{titlesec}
\newcommand{\cmcmsugost@sectionfont}{\fontsize{14pt}{16pt}\selectfont\bfseries}
\newlength{\cmcmsugost@titleskip}

\newcommand{\cmcmsugost@SetTitleSectionSty}{%
    \titleformat{\section}
    {\cmcmsugost@sectionfont}
    {\thesection\space}{0pt}{}[]
    \titlespacing*{\section}{0pt}{\cmcmsugost@titleskip}{\cmcmsugost@titleskip}

    \titleformat{\subsection}
    {\cmcmsugost@sectionfont}
    {\thesubsection\space}{0pt}{}[]
    \titlespacing*{\subsection}{0pt}{\cmcmsugost@titleskip}{\cmcmsugost@titleskip}

    \titleformat{\subsubsection}
    {\cmcmsugost@sectionfont}
    {\thesubsubsection\space}{0pt}{}[]
    \titlespacing*{\subsubsection}{0pt}{\cmcmsugost@titleskip}{\cmcmsugost@titleskip}
}

\newcommand{\cmcmsugost@SetTitleSty}{%
    \AtEndPreamble{%
        \setlength{\cmcmsugost@titleskip}{3\baselineskip}%
        \ifcmcmsugost@haschapter
            \titleformat{\chapter}
            {\cmcmsugost@sectionfont}
            {\chaptertitlename\space\thechapter.\space}
            {0pt}{}[]
            \titlespacing*{\chapter}{0pt}{-\headheight}{\cmcmsugost@titleskip}
        \else
        \fi
        \cmcmsugost@SetTitleSectionSty%
    }%
}

% Оглавление
\RequirePackage[titles]{tocloft}
\newcommand{\cmcmsugost@SetToCSty}{%
    \@ifundefined{captionsrussian}{}{%
        \addto\captionsrussian{%
            \renewcommand{\contentsname}{Оглавление}%
        }%
    }%

    \ifcmcmsugost@haschapter
        \renewcommand{\cftchappresnum}{Глава\ }
        \renewcommand{\cftchapaftersnum}{.\space}
        \settowidth{\cftchapnumwidth}{Глава 10.\ }
        \renewcommand{\cftchapleader}{\cftdotfill{\cftdotsep}}%
        \renewcommand{\cftchappagefont}{\normalfont}%
        \renewcommand{\cftchapaftersnum}{.\space}%
    \fi

    \renewcommand{\cftsecleader}{\cftdotfill{\cftdotsep}}%
    \renewcommand{\@tocrmarg}{2.55em plus 1fill}%
    \renewcommand{\cftsecpagefont}{\normalfont}%
    \renewcommand{\cftsecaftersnum}{.\space}%
    \renewcommand{\cftsubsecaftersnum}{.\space}%
    \renewcommand{\cftsubsubsecaftersnum}{.\space}%
}

% Русские буквы для нумерации
\newcommand{\cmcmsugost@patchrualpha}{%
    \ifPDFTeX
        \def\russian@Alph##1{\ifcase##1\or
                \CYRA\or\CYRB\or\CYRV\or\CYRG\or\CYRD\or\CYRE\or\CYRZH\or
                \CYRI\or\CYRK\or\CYRL\or\CYRM\or\CYRN\or
                \CYRP\or\CYRR\or\CYRS\or\CYRT\or\CYRU\or\CYRF\or\CYRH\or
                \CYRC\or\CYRSH\or\CYRSHCH\or\CYREREV\or\CYRYU\or\CYRYA%
            \else\@ctrerr\fi}%
        \def\russian@alph##1{\ifcase##1\or
                \cyra\or\cyrb\or\cyrv\or\cyrg\or\cyrd\or\cyre\or\cyrzh\or
                \cyri\or\cyrk\or\cyrl\or\cyrm\or\cyrn\or
                \cyrp\or\cyrr\or\cyrs\or\cyrt\or\cyru\or\cyrf\or\cyrh\or
                \cyrc\or\cyrsh\or\cyrshch\or\cyrerev\or\cyryu\or\cyrya%
            \else\@ctrerr\fi}%
    \else
        \def\russian@Alph##1{\ifcase##1\or
                А\or Б\or В\or Г\or Д\or Е\or Ж\or
                И\or К\or Л\or М\or Н\or
                П\or Р\or С\or Т\or У\or Ф\or Х\or
                Ц\or Ш\or Щ\or Э\or Ю\or Я%
            \else\@ctrerr\fi}%
        \def\russian@alph##1{\ifcase##1\or
                а\or б\or в\or г\or д\or е\or ж\or
                и\or к\or л\or м\or н\or
                п\or р\or с\or т\or у\or ф\or х\or
                ц\or ш\or щ\or э\or ю\or я%
            \else\@ctrerr\fi}%
    \fi
}

% Приложения
\newcommand{\cmcmsugost@SetAppendixSty}{%
    \ifcmcmsugost@haschapter
        \let\cmcmsugost@origchapter\chapter
        \newcommand{\cmcmsugost@appendixchapter}[1]{%
            \refstepcounter{chapter}%
            \cmcmsugost@origchapter*{Приложение \russian@Alph{\value{chapter}}\space ##1}%
            \addcontentsline{toc}{chapter}{Приложение \russian@Alph{\value{chapter}}.\space ##1}%
        }%
        \g@addto@macro\appendix{%
            \setcounter{chapter}{0}%
            \renewcommand{\thechapter}{\russian@Alph{\value{chapter}}}%
            \let\chapter\cmcmsugost@appendixchapter
        }%
    \else
        \let\cmcmsugost@origsection\section
        \newcommand{\cmcmsugost@appendixsection}[1]{%
            \refstepcounter{section}%
            \cmcmsugost@origsection*{Приложение \russian@Alph{\value{section}}\space ##1}%
            \addcontentsline{toc}{section}{Приложение \russian@Alph{\value{section}}.\space ##1}%
        }%
        \g@addto@macro\appendix{%
            \setcounter{section}{0}%
            \renewcommand{\thesection}{\russian@Alph{\value{section}}}%
            \let\section\cmcmsugost@appendixsection
        }%
    \fi
}

% "Стр." над номерами страниц в оглавлении
\RequirePackage{afterpage}
\newcommand{\cmcmsugost@ToCAddPageWord}{%
    \newif\ifendTOC
    \newcommand*{\tocheader}{%
        \ifendTOC\else
            \hbox to \linewidth{\hfill Стр.}\par
            \ifnumless{\value{page}}{3}{}{%
                \vspace{0.5\baselineskip}%
            }%
            \afterpage{\tocheader}%
        \fi
    }%
    \let\cmcmsugost@tableofcontentsORIG\tableofcontents
    \renewcommand{\tableofcontents}{%
        \cmcmsugost@tableofcontentsORIG
        \addtocontents{toc}{\protect\tocheader}%
        \endTOCtrue
        \newpage
    }%
}

% Списки
\RequirePackage{enumitem}
\newcommand{\cmcmsugost@SetListSty}{%
    \renewcommand{\labelitemi}{\normalfont\bfseries --}%
    \renewcommand{\labelitemii}{\normalfont\bfseries --}%
    \renewcommand{\labelitemiii}{\normalfont\bfseries --}%
    \renewcommand{\labelitemiv}{\normalfont\bfseries --}%

    \AddEnumerateCounter{\asbuk}{\russian@alph}{щ}%
    \renewcommand{\theenumii}{\asbuk{enumii}}%
    \renewcommand{\labelenumii}{\theenumii)}%
    \renewcommand{\theenumiii}{\arabic{enumiii}}%
    \renewcommand{\labelenumiii}{\theenumiii)}%

    \setlist{%
        nosep,
        labelindent=\parindent,
        leftmargin=*%
    }%
}

% Подписи
\RequirePackage{caption}
\RequirePackage{chngcntr}

\newcommand{\cmcmsugost@SetFigureSty}{%
    \DeclareCaptionLabelSeparator{figsep}{~---\ }%
    \captionsetup[figure]{%
        format=plain,
        font=normal,
        skip=\baselineskip,
        parskip=0pt,
        position=below,
        singlelinecheck=true,
        justification=centerlast,
        labelsep=figsep
    }%

    \DeclareCaptionSubType{figure}%
    \renewcommand{\thesubfigure}{\asbuk{subfigure}}%
    \DeclareCaptionFont{norm}{\fontsize{14pt}{16pt}\selectfont}%
    \captionsetup[subfigure]{%
        labelfont=norm,
        textfont=norm,
        labelsep=space,
        labelformat=brace,
        justification=centering,
        singlelinecheck=true,
        skip=\baselineskip,
        parskip=0pt,
        position=below
    }%
    \@ifundefined{c@chapter}{%
        \counterwithin{figure}{section}
    }{%
        \counterwithin{figure}{chapter}
    }
}

\newcommand{\cmcmsugost@SetTableSty}{%
    \DeclareCaptionLabelSeparator{tabsep}{~---\ }%
    \captionsetup[table]{%
        format=plain,
        font=normal,
        skip=0pt,
        parskip=0pt,
        position=above,
        justification=justified,
        indent=0pt,
        labelsep=tabsep,
        singlelinecheck=false
    }%
    \@ifundefined{c@chapter}{%
        \counterwithin{table}{section}
    }{%
        \counterwithin{table}{chapter}
    }
}

% Кириллица в subequations
\newcommand{\cmcmsugost@SetEquationSty}{%
    \AtBeginDocument{%
        \setlength{\abovedisplayskip}{8pt plus 2pt minus 3pt}
        \setlength{\belowdisplayskip}{8pt plus 2pt minus 3pt}
        \setlength{\abovedisplayshortskip}{4pt plus 1pt minus 1pt}
        \setlength{\belowdisplayshortskip}{4pt plus 1pt minus 1pt}
        \@ifundefined{subequations}{}{%
            \patchcmd{\subequations}
            {\def\theequation{\theparentequation\alph{equation}}}
            {\def\theequation{\theparentequation\asbuk{equation}}}
            {}{}%
        }%
    }%
    \@ifundefined{c@chapter}{%
        \counterwithin{equation}{section}
    }{%
        \counterwithin{equation}{chapter}
    }
}



% ------------------------------------------------
% Upright Greek by default in math mode
% Works with XeLaTeX/LuaLaTeX and pdfLaTeX
% ------------------------------------------------
\newcommand{\cmcmsugost@upgreek}{
    \ifPDFTeX%
        \@ifundefined{upalpha}{\RequirePackage{upgreek}}{}
        \AtEndPreamble{
            \let\alpha\upalpha%
            \let\beta\upbeta%
            \let\gamma\upgamma%
            \let\delta\updelta%
            \let\epsilon\upepsilon%
            \let\varepsilon\upvarepsilon%
            \let\theta\uptheta%
            \let\vartheta\upvartheta%
            \let\lambda\uplambda%
            \let\mu\upmu%
            \let\pi\uppi%
            \let\varpi\upvarpi%
            \let\rho\uprho%
            \let\varrho\upvarrho%
            \let\sigma\upsigma%
            \let\varsigma\upvarsigma%
            \let\phi\upphi%
            \let\varphi\upvarphi%
            \let\omega\upomega%
            \let\Gamma\Upgamma%
            \let\Delta\Updelta%
            \let\Theta\Uptheta%
            \let\Lambda\Uplambda%
            \let\Xi\Upxi%
            \let\Pi\Uppi%
            \let\Sigma\Upsigma%
            \let\Upsilon\Upupsilon%
            \let\Phi\Upphi%
            \let\Psi\Uppsi%
            \let\Omega\Upomega%
        }
    \else
        \RequirePackage{unicode-math}
        \AtEndPreamble{\unimathsetup{math-style=french}}
    \fi
}

\newcommand{\cmcmsugost@mathruop}{
    %%% Русская традиция начертания математических знаков
    \AtBeginDocument{
        %%% Русская традиция начертания математических функций
        \renewcommand{\tan}{\operatorname{tg}}
        \renewcommand{\cot}{\operatorname{ctg}}
        \renewcommand{\csc}{\operatorname{cosec}}
        \let\le\leqslant%
        \let\leq\leqslant%
        \let\ge\geqslant%
        \let\geq\geqslant%
        \let\phi\varphi%
        \let\epsilon\varepsilon%
        \let\kappa\varkappa%
        \let\emptyset\varnothing%
    }
}

\newcommand{\cmcmsugost@mathrutradition}{
    %% Break math symbol and repeat it in next line
    \RequirePackage{rmathbr}
    \cmcmsugost@mathruop%
}

\newcommand{\cmcmsugost@ApplySty}{%
    \cmcmsugost@patchrualpha%
    \cmcmsugost@FixOverfullBoxes%
    \cmcmsugost@SetTitleSty%
    \cmcmsugost@SetHeaderAndFooterSty%
    \cmcmsugost@SetToCSty%
    \cmcmsugost@SetAppendixSty%
    \cmcmsugost@SetFigureSty%
    \cmcmsugost@SetListSty%
    \cmcmsugost@SetEquationSty%
    \cmcmsugost@SetTableSty%
    \ifcmcmsugost@rumath%
        \cmcmsugost@mathrutradition%
    \else
        \ifcmcmsugost@upgreek%
            \cmcmsugost@upgreek%
        \fi
        \ifcmcmsugost@rumathop%
            \cmcmsugost@mathruop%
        \fi
    \fi
    \ifcmcmsugost@tocpageword%
        \cmcmsugost@ToCAddPageWord%

    \fi
    \RequirePackage{indentfirst}
    \RequirePackage{hyperref}
    \hypersetup{linktoc=page}

    \geometry{%
        a4paper,
        top=2cm,
        bottom=2cm,
        left=2.5cm,
        right=1cm,
        nomarginpar
    }%
    \onehalfspacing
    % Абзацный отступ. Должен быть одинаковым по всему тексту и
    % равен пяти знакам (ГОСТ Р 7.0.11-2011, 5.3.7).
    \AtBeginDocument{%
        \setlength{\parindent}{2.5em}
    }
}

\cmcmsugost@ApplySty%

