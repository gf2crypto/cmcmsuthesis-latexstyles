\newcommand{\cmcmsugost@SetBibLaTeX}{
    \RequirePackage{csquotes}
    \RequirePackage[%
        backend=biber,
        bibencoding=utf8,
        sorting=none,
        style=gost-numeric,
        autolang=other,
        clearlang=true,
        defernumbers=true,
        sortcites=true,
        doi=false,
        isbn=false,
    ]{biblatex}
    % # Исправление случая неподдержки знака номера в pdflatex
    \DefineBibliographyStrings{russian}{number={\textnumero}}
    \DeclareSourcemap{ % модификация bib-файла перед тем, как им займётся biblatex
        \maps{
            \map{% используем media=text по умолчанию
                \step[fieldset=media, fieldvalue=text]
            }
            \map{% перекидываем значения поля language в поле langid, которым пользуется biblatex
                \step[fieldsource=language, fieldset=langid, origfieldval, final]
                \step[fieldset=language, null]
            }
            \map{% перекидываем значения поля numpages в поле pagetotal, которым пользуется biblatex
                \step[fieldsource=numpages, fieldset=pagetotal, origfieldval, final]
                \step[fieldset=numpages, null]
            }
            \map{% перекидываем значения поля pagestotal в поле pagetotal, которым пользуется biblatex
                \step[fieldsource=pagestotal, fieldset=pagetotal, origfieldval, final]
                \step[fieldset=pagestotal, null]
            }
            \map[overwrite]{% если есть shortjournal, используем его вместо journal
                \step[fieldsource=shortjournal, final]
                \step[fieldset=journal, origfieldval]
                \step[fieldset=shortjournal, null]
            }
            \map[overwrite]{% если есть shortbooktitle, используем его вместо booktitle
                \step[fieldsource=shortbooktitle, final]
                \step[fieldset=booktitle, origfieldval]
                \step[fieldset=shortbooktitle, null]
            }
            \map[overwrite]{% если в поле medium написано "Электронный ресурс", устанавливаем media=eresource
                \step[fieldsource=medium,
                    match=\regexp{Электронный\s+ресурс},
                    final]
                \step[fieldset=media, fieldvalue=eresource]
                \step[fieldset=medium, null]
            }
            \map[overwrite]{% стираем значения всех полей issn
                \step[fieldset=issn, null]
            }
            \map[overwrite]{% стираем значения поля abstract, поскольку им не пользуемся, а там бывают проблемные символы
                \step[fieldsource=abstract]
                \step[fieldset=abstract, null]
            }
            \map[overwrite]{% переделка формата записи даты обращения
                \step[fieldsource=urldate,
                    match=\regexp{([0-9]{2})\.([0-9]{2})\.([0-9]{4})},
                    replace={$3-$2-$1$4},
                    final]
            }
            \map[overwrite]{% стираем ключевые слова
                \step[fieldsource=keywords]
                \step[fieldset=keywords, null]
            }
            \map[overwrite]{% для типа online перекидываем howpublished в organization
                \step[typesource=online, typetarget=online, final]
                \step[fieldsource=howpublished, fieldset=organization, origfieldval]
                \step[fieldset=howpublished, null]
            }
        }
    }

    % # В списке литературы обозначение одной буквой диапазона страниц англоязычного источника %%%
    \DefineBibliographyStrings{english}{%
        pages = {p\adddot} %заглавность буквы затем по месту определяется работой самого biblatex
    }
    % # Set higher penalty for breaking in number, dates and pages ranges
    \setcounter{abbrvpenalty}{10000} % default is \hyphenpenalty which is 12
    % # Set higher penalty for breaking in names
    \setcounter{highnamepenalty}{10000} % If you prefer the traditional BibTeX behavior (no linebreaks at highnamepenalty breakpoints), set it to ‘infinite’ (10 000 or higher).
    \setcounter{lownamepenalty}{10000}
}


\newcommand{\cmcmsugost@SetExtraMath}{
    \AtEndPreamble{
        \@ifpackageloaded{unicode-math}{}{%
            \newcommand{\symbf}[1]{\ensuremath{\boldsymbol{##1}}}
            \newcommand{\symbfit}[1]{\ensuremath{\boldsymbol{##1}}}
            \RequirePackage{upgreek}
            \newcommand{\symup}[1]{%
                \begingroup
                \edef\symup@name{\expandafter\@gobble\string##1}% alpha from \alpha
                \ifcsname up\symup@name\endcsname
                    \csname up\symup@name\endcsname
                \else
                    \mathrm{##1}%
                \fi
                \endgroup
            }
            \newcommand{\symbfup}[1]{\ensuremath{\boldsymbol{\symup{##1}}}}
        }
    }

    \newcommand{\vect}[1]{\symbfup{##1}}
    \newcommand{\matr}[1]{\symbfup{##1}}
    \newcommand{\code}[1]{\mathcal{##1}}
    \newcommand{\str}[1]{\symup{##1}}
    \newcommand{\elt}[1]{\symup{##1}}
    \newcommand{\crypto}[1]{\mathsf{##1}}
    \newcommand{\algo}[1]{\mathsf{##1}}
    \newcommand{\compl}[1]{\mathsf{##1}}
    \newcommand\scalemath[2]{\scalebox{##1}{\mbox{\ensuremath{\displaystyle ##2}}}}
}


