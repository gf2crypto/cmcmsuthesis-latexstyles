\cmcmsugost@EnableTheorems{
    \RequirePackage{amsthm}
    \RequirePackage{thmtools}
    %% Определения
    \declaretheorem[
        style=definition,
        numberwithin=section,
        name=\translate{Definition}]{definition}

    \declaretheorem[
        style=definition,
        numbered=no,
        name=\translate{Definition}]{definition*}
    %% Замечание
    \declaretheorem[
        style=remark,
        numberwithin=section,
        name=\translate{Remark}]{remark}
    \declaretheorem[
        style=remark,
        numbered=no,
        name=\translate{Remark}]{remark*}
    %% Пример
    \declaretheorem[
        style=definition,
        numberwithin=section,
        name=\translate{Example}]{example}
    \declaretheorem[
        name=\translate{Example},
        sibling=example]{exmpl}
    \declaretheorem[
        style=definition,
        numbered=no,
        name=\translate{Example}]{example*}
    %% Задача
    \declaretheorem[
        style=remark,
        numberwithin=section,
        name=\translate{Task}]{task}
    \declaretheorem[
        style=remark,
        numbered=no,
        name=\translate{Task}]{task*}
    %% Упражнение
    \declaretheorem[
        style=remark,
        numberwithin=section,
        name=\translate{Exercise}]{exercise}
    \declaretheorem[
        style=remark,
        numbered=no,
        name=\translate{Exercise}]{exercise*}
    %% Проблема
    \declaretheorem[
        style=remark,
        numberwithin=section,
        name=\translate{Problem}]{problem}
    \declaretheorem[
        style=remark,
        numbered=no,
        name=\translate{Problem}]{problem*}
    %% Вопрос
    \declaretheorem[
        style=remark,
        numberwithin=section,
        name=\translate{Question}]{question}
    \declaretheorem[
        style=remark,
        numbered=no,
        name=\translate{Question}]{question*}
    %% Теорема
    \declaretheorem[
        style=plain,
        numberwithin=section,
        name=\translate{Theorem}]{theorem}
    \declaretheorem[
        style=plain,
        numbered=no,
        name=\translate{Theorem}]{theorem*}
    %% Утверждение
    \declaretheorem[
        style=plain,
        numberwithin=section,
        name=\translate{Proposition}]{proposition}
    \declaretheorem[
        style=plain,
        numbered=no,
        name=\translate{Proposition}]{proposition*}
    \declaretheorem[
        style=plain,
        numberwithin=section,
        name=\translate{Assertion}]{assertion}
    \declaretheorem[
        style=plain,
        numbered=no,
        name=\translate{Assertion}]{assertion*}
    %% Лемма
    \declaretheorem[
        style=plain,
        numberwithin=section,
        name=\translate{Lemma}]{lemma}
    \declaretheorem[
        style=plain,
        numbered=no,
        name=\translate{Lemma}]{lemma*}
    %% Следствие
    \declaretheorem[
        style=plain,
        numberwithin=section,
        name=\translate{Corollary}]{corollary}
    \declaretheorem[
        style=plain,
        numbered=no,
        name=\translate{Corollary}]{corollary*}
}

\cmcmsugost@SetAlgorithm2e{
    \RequirePackage[%
        linesnumbered,
        titlenumbered
    ]{algorithm2e}
    \SetKwInput{KwData}{\translate{Input}}
    \SetKwInput{KwInput}{\translate{Input}}
    \SetKwInput{KwOutput}{\translate{Output}}
    \SetKwInput{KwResult}{\translate{Output}}
    \SetAlgorithmName{\translate{Algorithm}}{
        \translate{algorithm}}{\translate{List of algorithms}}

    \SetKwComment{Comment}{/* }{ */}
}

# Включение в документ листингов
\RequirePackage{listings}

# Ширина текста минус ширина надписи 999
\newlength{\twless}
\newlength{\lmarg}
\setlength{\lmarg}{\widthof{999}}   % ширина надписи 999
\setlength{\twless}{\textwidth-\lmarg}
\lstset{ %
    numbers=left,                   % where to put the line-numbers
    numberstyle=\fontsize{12pt}{14pt}\selectfont\color{Gray},  % the style that is used for the line-numbers
    firstnumber=1,                  % в этой и следующей строках задаётся поведение нумерации 5, 10, 15...
    stepnumber=5,                   % the step between two line-numbers. If it's 1, each line will be numbered
    numbersep=5pt,                  % how far the line-numbers are from the code
    backgroundcolor=\color{white},  % choose the background color. You must add \RequirePackage{color}
    showspaces=false,               % show spaces adding particular underscores
    showstringspaces=false,         % underline spaces within strings
    showtabs=false,                 % show tabs within strings adding particular underscores
    frame=leftline,                 % adds a frame of different types around the code
    rulecolor=\color{black},        % if not set, the frame-color may be changed on line-breaks within not-black text (e.g. commens (green here))
    tabsize=2,                      % sets default tabsize to 2 spaces
    captionpos=t,                   % sets the caption-position to top
    breaklines=true,                % sets automatic line breaking
    breakatwhitespace=false,        % sets if automatic breaks should only happen at whitespace
    title=\lstname,                 % show the filename of files included with \lstinputlisting; also try caption instead of title
    basicstyle=\fontsize{12pt}{14pt}\selectfont\ttfamily,% the size of the fonts that are used for the code
    keywordstyle=\color{blue},      % keyword style
    commentstyle=\color{ForestGreen}\emph,% comment style
    stringstyle=\color{Mahogany},   % string literal style
    escapeinside={\%*}{*)},         % if you want to add a comment within your code
    morekeywords={*,...},           % if you want to add more keywords to the set
    inputencoding=utf8,             % кодировка кода
    xleftmargin={\lmarg},           % Чтобы весь код и полоска с номерами строк была смещена влево, так чтобы цифры не вылезали за пределы текста слева
}

