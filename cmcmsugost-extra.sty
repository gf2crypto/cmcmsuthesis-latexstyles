\newcommand{\cmcmsugost@SetTheorems}{
    \RequirePackage{amsthm}
    \RequirePackage{thmtools}
    %% Определения
    \declaretheorem[
        style=definition,
        numberwithin=section,
        name=\translate{Definition}]{definition}

    \declaretheorem[
        style=definition,
        numbered=no,
        name=\translate{Definition}]{definition*}
    %% Замечание
    \declaretheorem[
        style=remark,
        numberwithin=section,
        name=\translate{Remark}]{remark}
    \declaretheorem[
        style=remark,
        numbered=no,
        name=\translate{Remark}]{remark*}
    %% Пример
    \declaretheorem[
        style=definition,
        numberwithin=section,
        name=\translate{Example}]{example}
    \declaretheorem[
        name=\translate{Example},
        sibling=example]{exmpl}
    \declaretheorem[
        style=definition,
        numbered=no,
        name=\translate{Example}]{example*}
    %% Задача
    \declaretheorem[
        style=remark,
        numberwithin=section,
        name=\translate{Task}]{task}
    \declaretheorem[
        style=remark,
        numbered=no,
        name=\translate{Task}]{task*}
    %% Упражнение
    \declaretheorem[
        style=remark,
        numberwithin=section,
        name=\translate{Exercise}]{exercise}
    \declaretheorem[
        style=remark,
        numbered=no,
        name=\translate{Exercise}]{exercise*}
    %% Проблема
    \declaretheorem[
        style=remark,
        numberwithin=section,
        name=\translate{Problem}]{problem}
    \declaretheorem[
        style=remark,
        numbered=no,
        name=\translate{Problem}]{problem*}
    %% Вопрос
    \declaretheorem[
        style=remark,
        numberwithin=section,
        name=\translate{Question}]{question}
    \declaretheorem[
        style=remark,
        numbered=no,
        name=\translate{Question}]{question*}
    %% Теорема
    \declaretheorem[
        style=plain,
        numberwithin=section,
        name=\translate{Theorem}]{theorem}
    \declaretheorem[
        style=plain,
        numbered=no,
        name=\translate{Theorem}]{theorem*}
    %% Утверждение
    \declaretheorem[
        style=plain,
        numberwithin=section,
        name=\translate{Proposition}]{proposition}
    \declaretheorem[
        style=plain,
        numbered=no,
        name=\translate{Proposition}]{proposition*}
    \declaretheorem[
        style=plain,
        numberwithin=section,
        name=\translate{Assertion}]{assertion}
    \declaretheorem[
        style=plain,
        numbered=no,
        name=\translate{Assertion}]{assertion*}
    %% Лемма
    \declaretheorem[
        style=plain,
        numberwithin=section,
        name=\translate{Lemma}]{lemma}
    \declaretheorem[
        style=plain,
        numbered=no,
        name=\translate{Lemma}]{lemma*}
    %% Следствие
    \declaretheorem[
        style=plain,
        numberwithin=section,
        name=\translate{Corollary}]{corollary}
    \declaretheorem[
        style=plain,
        numbered=no,
        name=\translate{Corollary}]{corollary*}
}

\newcommand{\cmcmsugost@SetAlgorithmE}{
    \RequirePackage[%
        linesnumbered,
        titlenumbered
    ]{algorithm2e}
    \RequirePackage{xcolor}
    \definecolor{AlgoRule}{gray}{0.35}
    \definecolor{AlgoNumbers}{gray}{0.45}
    \definecolor{AlgoText}{gray}{0.05}
    \definecolor{AlgoComment}{gray}{0.35}
    \SetKwInput{KwData}{\translate{Input}}
    \SetKwInput{KwInput}{\translate{Input}}
    \SetKwInput{KwOutput}{\translate{Output}}
    \SetKwInput{KwResult}{\translate{Output}}
    \SetAlgorithmName{\translate{Algorithm}}{
        \translate{algorithm}}{\translate{List of algorithms}}
    \SetKwComment{Comment}{/* }{ */}
    \SetAlgoNlRelativeSize{0} % номера строк того же размера
    \newcommand{\cmcmsugost@AlgoNlSty}[1]{%
        \fontsize{12pt}{14pt}\selectfont\color{AlgoNumbers}##1%
    }
    \SetNlSty{cmcmsugost@AlgoNlSty}{}{}%
    \SetAlgoCaptionLayout{centerline}
    \SetAlgoInsideSkip{smallskip}
    \SetAlgoSkip{smallskip}
    \SetAlgoVlined% вертикальные линии блоков (как в книгах)

    \SetAlCapFnt{\fontsize{12pt}{14pt}\selectfont}
    \SetAlCapNameFnt{\fontsize{12pt}{14pt}\selectfont}

    \SetAlFnt{\fontsize{12pt}{14pt}\selectfont\ttfamily\color{AlgoText}}

    \newcommand{\cmcmsugost@AlgoCommentStyle}[1]{%
        \itshape\color{AlgoComment}##1%
    }%
    \SetCommentSty{cmcmsugost@AlgoCommentStyle}%

}

